{
  "name": "FASM",
  "scopeName": "source.fasm",
  "fileTypes": ["asm", "inc", "fasm", "fas"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#include-directive" },
    { "include": "#label-definition" },
    { "include": "#struct-body" },
    { "include": "#macro-struct-definition" },
    { "include": "#purge-statement" },
    { "include": "#constant-definition" },
    { "include": "#calm-commands" },
    { "include": "#data-directives" },
    { "include": "#directives" },
    { "include": "#format-keywords" },
    { "include": "#size-specifiers" },
    { "include": "#registers" },
    { "include": "#mnemonics" },
    { "include": "#special-symbols" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.semicolon.fasm",
      "match": ";.*$"
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.fasm",
          "begin": "'",
          "end": "'",
          "patterns": [{ "match": "''", "name": "constant.character.escape.fasm" }]
        },
        {
          "name": "string.quoted.double.fasm",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "match": "\"\"", "name": "constant.character.escape.fasm" }]
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.float.fasm", "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b" },
        { "name": "constant.numeric.hex.fasm", "match": "\\b0[xX][0-9A-Fa-f_]+\\b" },
        { "name": "constant.numeric.hex.fasm", "match": "\\$[0-9A-Fa-f_]+\\b" },
        { "name": "constant.numeric.hex.fasm", "match": "\\b[0-9][0-9A-Fa-f_]*[hH]\\b" },
        { "name": "constant.numeric.binary.fasm", "match": "\\b[01][01_]*[bB]\\b" },
        { "name": "constant.numeric.octal.fasm", "match": "\\b[0-7][0-7_]*[oOqQ]\\b" },
        { "name": "constant.numeric.decimal.fasm", "match": "\\b[0-9][0-9_]*\\b" }
      ]
    },
    "include-directive": {
      "match": "^\\s*(include|file)\\b",
      "captures": { "1": { "name": "keyword.control.import.fasm" } }
    },
    "label-definition": {
      "comment": "The \"::\" (area label) case must come before the plain single-\":\" cases below: they only look at the first \":\", so \"area::\" would otherwise match as an ordinary label and leave the second \":\" unstyled.",
      "patterns": [
        {
          "match": "^\\s*([A-Za-z_.@$?][A-Za-z0-9_.@$?]*)\\s*(::)",
          "captures": {
            "1": { "name": "entity.name.label.fasm" },
            "2": { "name": "punctuation.separator.label.fasm" }
          }
        },
        {
          "match": "^\\s*(\\.[A-Za-z_.@$?][A-Za-z0-9_.@$?]*)\\s*(:)",
          "captures": {
            "1": { "name": "entity.name.label.local.fasm" },
            "2": { "name": "punctuation.separator.label.fasm" }
          }
        },
        {
          "match": "^\\s*([A-Za-z_@$?][A-Za-z0-9_.@$?]*)\\s*(:)(?!=)",
          "captures": {
            "1": { "name": "entity.name.label.fasm" },
            "2": { "name": "punctuation.separator.label.fasm" }
          }
        },
        {
          "match": "\\b(label)\\s+([A-Za-z_.@$?][A-Za-z0-9_.@$?]*)",
          "captures": {
            "1": { "name": "keyword.control.directive.fasm" },
            "2": { "name": "entity.name.label.fasm" }
          }
        }
      ]
    },
    "macro-struct-definition": {
      "match": "\\b(macro|struct)\\s+([A-Za-z_.@$?][A-Za-z0-9_.@$?]*\\??)",
      "captures": {
        "1": { "name": "keyword.control.directive.fasm" },
        "2": { "name": "entity.name.function.fasm" }
      }
    },
    "purge-statement": {
      "comment": "The names following \"purge\" are macro/instruction-class names being un-defined, not keywords — without this taking priority, a purged name that happens to spell a reserved word (e.g. \"dword?\"/\"qword?\", real macro names generated by fasmg's own packages/x86/include/macro/proc64.inc's \"locals?\" macro) would be wrongly highlighted as the unrelated size-specifier keyword.",
      "begin": "^\\s*(purge)\\b",
      "beginCaptures": { "1": { "name": "keyword.control.directive.fasm" } },
      "end": "$",
      "patterns": [{ "include": "#comments" }, { "match": "[A-Za-z_.@$?][A-Za-z0-9_.@$?]*\\??", "name": "entity.name.function.fasm" }]
    },
    "struct-body": {
      "comment": "A struct's own field names are plain member identifiers, not keywords — without this as its own block, a field named e.g. \"segment\" or \"offset\" (both real field names in fasmg's own packages/x86/projects/challenger/challenger.asm) would be wrongly highlighted as the unrelated \"segment\" format directive, since the generic #directives pattern otherwise matches that word anywhere.",
      "begin": "\\b(struct)\\s+([A-Za-z_.@$?][A-Za-z0-9_.@$?]*\\??)",
      "beginCaptures": {
        "1": { "name": "keyword.control.directive.fasm" },
        "2": { "name": "entity.name.function.fasm" }
      },
      "end": "\\b(ends)\\b",
      "endCaptures": { "1": { "name": "keyword.control.directive.fasm" } },
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "match": "^\\s*([A-Za-z_.@$?][A-Za-z0-9_.@$?]*)", "captures": { "1": { "name": "variable.other.member.fasm" } } },
        { "include": "#size-specifiers" },
        { "include": "#data-directives" },
        { "include": "#directives" },
        { "include": "#operators" }
      ]
    },
    "constant-definition": {
      "comment": "\":=\" (defined exactly once, forward-reference-safe) and \"=:\" (preserves the previous value, restorable with `restore`) must be checked before the plain \"=\" pattern -- fasmg requires no space between the two characters (confirmed against the real compiler: \"X : = 1\" fails to assemble, parsed as a label \"X:\" followed by an invalid \"= 1\"), so unlike \"equ\"/\"reequ\" this isn't a separate keyword the plain \"=\" pattern could otherwise be taught to skip over.",
      "patterns": [
        {
          "match": "^\\s*([A-Za-z_.@$?][A-Za-z0-9_.@$?]*)\\s*(:=)",
          "captures": {
            "1": { "name": "variable.other.constant.fasm" },
            "2": { "name": "keyword.operator.assignment.fasm" }
          }
        },
        {
          "match": "^\\s*([A-Za-z_.@$?][A-Za-z0-9_.@$?]*)\\s*(=:)",
          "captures": {
            "1": { "name": "variable.other.constant.fasm" },
            "2": { "name": "keyword.operator.assignment.fasm" }
          }
        },
        {
          "match": "^\\s*([A-Za-z_.@$?][A-Za-z0-9_.@$?]*)\\s*(=)(?![=:])",
          "captures": {
            "1": { "name": "variable.other.constant.fasm" },
            "2": { "name": "keyword.operator.assignment.fasm" }
          }
        },
        {
          "match": "^\\s*([A-Za-z_.@$?][A-Za-z0-9_.@$?]*)\\s+(equ|reequ)\\b",
          "captures": {
            "1": { "name": "variable.other.constant.fasm" },
            "2": { "name": "keyword.control.directive.fasm" }
          }
        },
        {
          "comment": "\"load NAME[:size] from ADDRESS\" defines NAME by reading bytes back out of an output area (see fasmg's own packages/x86/include/macro/proc64.inc: \"load value:byte from area:pointer\").",
          "match": "^\\s*(load)\\s+([A-Za-z_.@$?][A-Za-z0-9_.@$?]*)",
          "captures": {
            "1": { "name": "keyword.control.directive.fasm" },
            "2": { "name": "variable.other.constant.fasm" }
          }
        }
      ]
    },
    "calm-commands": {
      "comment": "fasmg's CALM (Compiled Assembly-Like Macro) sub-language, used inside calminstruction/postpone bodies — kept as its own scope (matching hover's distinct \"CALM command\" tag) rather than lumped in with ordinary directives, since it's a genuinely different sublanguage. \"call\" and \"jno\" are deliberately left out despite also being CALM commands: both are far more commonly the real x86 CALL/JNO instructions, and this grammar has no notion of \"inside a calminstruction body\" to disambiguate the two.",
      "name": "keyword.other.calm.fasm",
      "match": "(?i)\\b(calminstruction|postpone|match|arrange|assemble|emit|compute|check|element|jump|jyes|exit|publish|transform|stringify|take|taketext|initsym)\\b"
    },
    "data-directives": {
      "comment": "Directives that reserve/declare typed storage (db/dw/dd/... and their r-prefixed \"reserve\" counterparts) get the same storage.type family as #size-specifiers, since they're the same underlying concept (a type/width), just declaring storage instead of just naming a width.",
      "name": "storage.type.data.fasm",
      "match": "(?i)\\b(db|dw|dd|dp|df|dq|dt|ddq|dqq|ddqq|du|rb|rw|rd|rp|rf|rq|rt|rdq|rqq|rdqq|file)\\b"
    },
    "directives": {
      "name": "keyword.control.directive.fasm",
      "match": "(?i)\\b(format|use16|use32|use64|use|org|entry|section|segment|virtual|end|macro|struc|struct|ends|if|else|while|repeat|rept|irp|irpv|iterate|namespace|include|assert|display|err|local|common|forward|reverse|equ|reequ|define|redefine|restore|purge|load|store|from|align|times|at|label)\\b"
    },
    "size-specifiers": {
      "name": "storage.type.fasm",
      "match": "(?i)\\b(byte|word|dword|fword|pword|qword|tbyte|tword|dqword|xword|qqword|yword|dqqword|zword|ptr|near|far|short)\\b"
    },
    "format-keywords": {
      "name": "support.constant.format.fasm",
      "match": "(?i)\\b(binary|MZ|PE64|PE|COFF|MS64|MS|MachO64|MachO|ELF64|ELFx32|ELF|console|GUI|native|DLL|WDM|EFIboot|EFIruntime|efi|as|at|executable|dynamic|large|NX|on|readable|writeable|discardable|shareable|interpreter|note|gnustack|gnuehframe|gnurelro)\\b"
    },
    "registers": {
      "name": "variable.language.register.fasm",
      "match": "(?i)\\b(xmm1[0-5]|xmm[0-9]|ymm[0-7]|zmm[0-3]|r1[0-5][dwb]?|r[89][dwb]?|spl|bpl|sil|dil|e[a-d]x|e[sb]p|e[sd]i|r[a-d]x|r[sb]p|r[sd]i|st[0-7]|mm[0-7]|cr[0-4]|cr8|dr[0-3]|dr[67]|k[0-7]|[a-d][lh]|[a-d]x|sp|bp|si|di|rip|eip|ip|cs|ds|es|fs|gs|ss)\\b"
    },
    "mnemonics": {
      "name": "keyword.other.mnemonic.fasm",
      "match": "(?i)\\b(cmpxchg16b|vzeroupper|cmpxchg8b|sysenter|syscall|cmpxchg|vmovaps|movsxd|popcnt|loopne|cmovne|movaps|movups|movapd|movdqa|movdqu|movzx|movsx|pushf|lzcnt|tzcnt|jecxz|jrcxz|loope|setne|cmove|cmovg|cmovl|cpuid|rdtsc|movsb|movsw|movsd|movsq|stosb|stosw|stosd|stosq|repne|leave|enter|movss|addss|addps|subss|mulss|divss|wrmsr|rdmsr|xchg|push|popf|imul|idiv|test|shld|shrd|call|retn|retf|jcxz|loop|sete|setg|setl|seta|setb|int3|movs|cmps|scas|stos|lods|repe|lock|xadd|cwde|cdqe|wait|fstp|fadd|fsub|fmul|fdiv|pxor|pand|mov|lea|pop|add|adc|sub|sbb|inc|dec|neg|mul|div|cmp|and|xor|not|shl|sal|shr|sar|rol|ror|rcl|rcr|bts|btr|btc|bsf|bsr|jmp|ret|jne|jnz|jge|jle|jae|jbe|jnc|jno|jns|jnp|nop|hlt|int|cld|std|clc|stc|cmc|cli|sti|rep|cbw|cwd|cdq|cqo|fld|fst|por|out|or|bt|je|jz|jg|jl|ja|jb|jc|jo|js|jp|in)\\b"
    },
    "special-symbols": {
      "comment": "fasmg's built-in, never-user-defined pseudo-variables: \"$\"/\"$$\"/\"$@\" (current address / current addressing-space base / current reserved-data-block base) and \"%\"/\"%%\" (current repetition number / total planned repetitions, inside repeat-while-iterate) — kept as their own scope (matching hover's distinct \"Built-in symbol\" tag) rather than falling through to the generic operator class, since e.g. \"if % = %%\" (a real, common check inside fasmg's own prologue/epilogue macros) is easy to misread as an operator soup without this. Checked after #numbers, which already claims a \"$\" immediately followed by a hex digit (fasmg's \"$1A\"-style hex literal) — a bare \"$\"/\"$$\"/\"$@\" is never one of those.",
      "name": "variable.language.special.fasm",
      "match": "\\$\\$|\\$@|\\$|%%|%"
    },
    "operators": {
      "name": "keyword.operator.fasm",
      "match": "(?i)\\b(and|or|xor|not|shl|shr|mod|ptr|dup)\\b|[+\\-*/<>=!&|~]"
    }
  }
}
